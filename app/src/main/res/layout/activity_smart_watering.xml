<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#4CAF50"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_back"
                android:padding="12dp"
                android:contentDescription="Back"
                app:tint="@android:color/white" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="🤖 Умный полив"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@android:color/white" />

            <ImageView
                android:id="@+id/btnAdd"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_add"
                android:padding="12dp"
                android:contentDescription="Add"
                app:tint="@android:color/white" />

        </RelativeLayout>

    </androidx.appcompat.widget.Toolbar>

    <!-- Инструкция -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📸 Сфотографируй растение — AI определит, когда поливать"
        android:textSize="14sp"
        android:textColor="#757575"
        android:gravity="center"
        android:padding="12dp"
        android:background="#E8F5E9" />

    <!-- Пустое состояние -->
    <LinearLayout
        android:id="@+id/emptyState"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone"
        android:padding="32dp">

        <ImageView
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:src="@drawable/ic_flower"
            android:layout_marginBottom="16dp"
            app:tint="#4CAF50" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🌱 Нет умных напоминаний"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#333333" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Нажми +, сфотографируй растение, и AI создаст персональный график полива"
            android:textSize="14sp"
            android:textColor="#757575"
            android:gravity="center"
            android:layout_marginTop="8dp" />

        <Button
            android:id="@+id/btnAddFirst"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="➕ Добавить растение"
            android:textAllCaps="false"
            android:backgroundTint="#4CAF50"
            android:layout_marginTop="24dp" />

    </LinearLayout>

    <!-- Список напоминаний -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="8dp"
        android:clipToPadding="false"
        android:visibility="visible" />

</LinearLayout>