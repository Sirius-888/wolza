<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme -->
    <style name="Theme.ArduinoApp" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">#00979D</item>  <!-- Arduino teal color -->
        <item name="colorPrimaryVariant">#007A7E</item>
        <item name="colorOnPrimary">@color/white</item>

        <!-- Secondary brand color -->
        <item name="colorSecondary">#FFA500</item>  <!-- Orange accent -->
        <item name="colorSecondaryVariant">#FF8C00</item>
        <item name="colorOnSecondary">@color/black</item>

        <!-- Status bar color -->
        <item name="android:statusBarColor" tools:targetApi="l">?attr/colorPrimaryVariant</item>

        <!-- Window background -->
        <item name="android:windowBackground">@color/white</item>
    </style>
</resources>