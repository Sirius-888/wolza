<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Back up shared preferences -->
        <include domain="sharedpref" path="."/>

        <!-- Back up database -->
        <include domain="database" path="."/>
    </cloud-backup>

    <device-transfer>
        <!-- Transfer shared preferences -->
        <include domain="sharedpref" path="."/>

        <!-- Transfer database -->
        <include domain="database" path="."/>
    </device-transfer>
</data-extraction-rules>